# --- Telegram bot ---
BOT_TOKEN=PUT_YOUR_TELEGRAM_BOT_TOKEN_HERE

# --- Backend ---
BACKEND_URL=http://backend:8000

# --- PostgreSQL ---
DB_USER=dating
DB_PASS=dating
DB_NAME=dating
POSTGRES_HOST_PORT=5433
DATABASE_URL=postgresql+asyncpg://dating:dating@db:5432/dating

# --- Redis ---
REDIS_HOST_PORT=6379
REDIS_URL=redis://redis:6379
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- RabbitMQ ---
RABBITMQ_DEFAULT_USER=dating
RABBITMQ_DEFAULT_PASS=dating
RABBITMQ_HOST_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_URL=amqp://dating:dating@rabbitmq:5672/

# --- MinIO ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_HOST_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_BUCKET=photos
MINIO_REGION=us-east-1

# --- Backend ports ---
BACKEND_HOST_PORT=8000

# --- container/network names ---
NETWORK_NAME=dating_network
NETWORK_DRIVER=bridge
CONTAINER_DB_NAME=dating_db
CONTAINER_REDIS_NAME=dating_redis
CONTAINER_BACKEND_NAME=dating_backend
CONTAINER_CELERY_WORKER_NAME=dating_celery_worker
CONTAINER_CELERY_BEAT_NAME=dating_celery_beat
CONTAINER_BOT_NAME=dating_bot
CONTAINER_RABBITMQ_NAME=dating_rabbitmq
CONTAINER_MINIO_NAME=dating_minio
